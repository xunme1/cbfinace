# Polygon API keys. You can configure one or multiple keys.
# Multiple keys are rotated by the downloader/update scripts.
POLYGON_API_KEY_1=your_polygon_api_key_1
POLYGON_API_KEY_2=
POLYGON_API_KEY_3=

# Backward-compatible single-key variable. Leave empty if you use POLYGON_API_KEY_1.
POLYGON_API_KEY=


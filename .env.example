# Backend CORS allowlist. Split multiple origins with commas.
FRONTEND_ORIGINS=http://127.0.0.1:5173,http://localhost:5173,https://cbfinace.vercel.app

# Scraper login state. Put auth.json at backend/auth.json or set an absolute path here.
JYKC_AUTH_FILE=
JYKC_BROWSER_CHANNEL=
JYKC_HEADLESS=true
JYKC_AUTO_SCRAPE_ON_MISSING=true

# Optional daily scraper. Disabled by default.
JYKC_SCHEDULER_ENABLED=false
JYKC_SCHEDULER_TIME=17:30
